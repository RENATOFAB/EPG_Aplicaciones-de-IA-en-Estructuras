#!/usr/bin/env python3
"""Convierte Concrete_Data.xls (UCI) a Concrete_Data.csv con columnas en español."""

import argparse
from pathlib import Path
import pandas as pd

SPANISH_COLUMNS = {
    'cement': 'Cemento (kg/m³)',
    'blast furnace slag': 'Escoria de alto horno (kg/m³)',
    'fly ash': 'Ceniza volante (kg/m³)',
    'water': 'Agua (kg/m³)',
    'superplasticizer': 'Superplastificante (kg/m³)',
    'coarse aggregate': 'Agregado grueso (kg/m³)',
    'fine aggregate': 'Agregado fino (kg/m³)',
    'age': 'Edad del concreto (días)',
    'concrete compressive strength': 'Resistencia a compresión (MPa)'
}


def find_file(name=None):
    if name:
        candidate = Path(name)
        if candidate.exists():
            return candidate
    candidates = list(Path('.').rglob('*.xls'))
    if not candidates:
        return None
    if name:
        for candidate in candidates:
            if candidate.name.lower() == Path(name).name.lower():
                return candidate
    return candidates[0]


def spanish_columns(columns):
    translated = []
    for column in columns:
        normalized = str(column).strip()
        lower = normalized.lower()
        translated_name = next(
            (spanish for key, spanish in SPANISH_COLUMNS.items() if key in lower),
            normalized
        )
        translated.append(translated_name)
    return translated


def parse_args():
    parser = argparse.ArgumentParser(
        description='Convierte Concrete_Data.xls a Concrete_Data.csv con columnas en español.'
    )
    parser.add_argument(
        'input',
        nargs='?',
        help='Archivo Excel de entrada (.xls). Si no se indica, busca Concrete_Data.xls en el workspace.'
    )
    parser.add_argument(
        '-o',
        '--output',
        help='Archivo CSV de salida. Si no se indica, usa Concrete_Data.csv en el directorio actual.'
    )
    return parser.parse_args()


def main():
    args = parse_args()
    source = find_file(args.input)
    if source is None:
        raise SystemExit('No se encontró ningún archivo .xls en el workspace.')

    output = Path(args.output) if args.output else Path('Concrete_Data.csv')
    if output.is_dir():
        output = output / 'Concrete_Data.csv'
    if output.suffix.lower() != '.csv':
        output = output.with_suffix('.csv')
    output.parent.mkdir(parents=True, exist_ok=True)

    df = pd.read_excel(source, engine='xlrd')
    df.columns = spanish_columns(df.columns)
    df.to_csv(output, index=False, encoding='utf-8')

    print(f'Archivo convertido: {output}')
    print(f'Columnas: {list(df.columns)}')
    print(f'Registros: {len(df)}')


if __name__ == '__main__':
    main()
